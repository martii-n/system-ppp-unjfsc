FROM php:8.4-fpm

# Instalar dependencias del sistema (Agregamos Node.js aquí de forma limpia)
RUN apt-get update && apt-get install -y \
    git \
    unzip \
    zip \
    curl \
    libpng-dev \
    libjpeg-dev \
    libfreetype6-dev \
    libonig-dev \
    libxml2-dev \
    libzip-dev \
    mariadb-client \
    && curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs

# Instalar extensiones PHP
RUN docker-php-ext-configure gd --with-freetype --with-jpeg \
    && docker-php-ext-install pdo_mysql mbstring zip exif pcntl gd bcmath

# Instalar Composer
RUN curl -sS https://getcomposer.org/installer | php && \
    mv composer.phar /usr/local/bin/composer && \
    chmod +x /usr/local/bin/composer

WORKDIR /var/www

# Copiar archivos de configuración para aprovechar la caché de capas de Docker
COPY composer.json composer.lock ./
RUN composer install --no-interaction --no-scripts --no-autoloader

# Nota: Quitamos los comandos COPY . . y npm ci de aquí para desarrollo.
# Los archivos se sincronizan mediante los volúmenes de docker-compose
# y las dependencias las instalaremos al levantar el contenedor.

EXPOSE 8000 5173

# Usaremos un script de entrada (entrypoint) o el comando directo en docker-compose